  "item": [
    {
      "name": "School Admin",
      "item": [
        {
          "name": "POST add-behaviour (no subject_id) -> 200/201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Behavior Type Admin\"\n}"
            },
            "url": "{{baseUrl}}/api/add-behaviour"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 201', function () {",
                  "  pm.expect([200,201]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST add-studentBehaviour (no subject_id) -> 200/201",
